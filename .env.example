# ── Backend (Render / local) ─────────────────────────────────────────────────
# Primary Groq API key — used by heavy reasoning nodes
# (synthesis, context analysis, recommendations, RAG chat).
GROQ_API_KEY=your_groq_api_key_here

# Secondary Groq API key — used by extraction and pattern nodes
# (extract_parameters, model2_patterns) AND as the fallback key for
# primary-key failures. Splitting load across two keys doubles effective
# TPM and prevents 429 rate-limit errors on high-volume requests.
# If left blank, the system falls back to GROQ_API_KEY for all calls.
GROQ_API_KEY_2=your_second_groq_api_key_here

HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Backend URL (used by Streamlit app) — default: http://localhost:8000
BACKEND_URL=http://localhost:8000

# Comma-separated list of allowed frontend origins
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Frontend (Vercel env vars) ────────────────────────────────────────────────
# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Backend URL — server-side only (NOT NEXT_PUBLIC_)
# Local Docker:  http://backend:8000
# Production:    https://health-ai-backend.onrender.com  (your Render service URL)
FASTAPI_URL=https://health-ai-backend.onrender.com

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=8000
